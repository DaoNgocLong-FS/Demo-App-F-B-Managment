# =====================================================
# RestoManager - Cấu hình triển khai (Docker Compose)
# Sao chép file này thành `.env` rồi chỉnh sửa nếu cần.
# =====================================================

# --- PostgreSQL ---
DB_NAME=restaurant_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT_HOST=5432

# --- JWT ---
JWT_SECRET=please-change-me-in-prod
JWT_EXPIRES=12h

# --- MinIO ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=restaurant
MINIO_PORT_HOST=9000
MINIO_CONSOLE_PORT=9001
# URL công khai (truy cập từ trình duyệt) tới MinIO; mặc định localhost
MINIO_PUBLIC_URL=http://localhost:9000

# --- Cổng dịch vụ ---
BACKEND_PORT_HOST=3000
FRONTEND_PORT_HOST=8080
